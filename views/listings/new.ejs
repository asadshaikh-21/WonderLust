<%- layout("layouts/boilerplate.ejs") %>
<div class="row mt-2">
<div class="col-8 offset-2">
    <br/>
<h1>Create New Listing</h1>
    <br>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label><br>
            <input name ="listing[title]" 
            placeholder="Write a cachy title" 
            type="text" 
            class="form-control"
            required>
            <div class="valid-feedback">Title Looks Good!</div>
            <div class="invalid-feedback">Please Enter the Title</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea 
                name="listing[description]" 
                class="form-control" 
                rows="4"
                placeholder="Write a short description "
                required
            ></textarea>
            <div class="invalid-feedback">Please Enter the Description</div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Upload Image</label>
            <input name ="listing[image]" 
            type="file" 
            class="form-control"
            required>
        </div>
        <div class="row">

            <div class="mb-3">
            <label class="form-label">Category</label>
            <select name="listing[category]" class="form-select" required>
                <option value="Trending">Trending</option>
                <option value="Room">Room</option>
                <option value="City">City</option>
                <option value="Mountain">Mountain</option>
                <option value="Castle">Castle</option>
                <option value="Pool">Pool</option>
                <option value="Camping">Camping</option>
                <option value="Farms">Farms</option>
                <option value="Morden">Morden</option>
                <option value="Snow">Snow</option>
                <option value="Artic">Artic</option>
            </select>
            </div>

            <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name ="listing[price]" 
            placeholder="1200" 
             
            class="form-control"
            required>
            <div class="invalid-feedback">Please Enter the correct price</div>
        </div>
        <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input name ="listing[country]" placeholder="India" type="text" class="form-control"
            required>
            <div class="invalid-feedback">Please Enter the Country</div>
        </div>
        </div>
        <div class="mb-3 ">
            <label for="location" class="form-label">Location</label>
            <input name ="listing[location]" 
            placeholder="Mumbai,Pune,etc" 
            type="text" 
            class="form-control"
            required>
            <div class="invalid-feedback">Please Enter Location</div>
        </div>
        <button class="btn btn-dark mt-3 mb-5">Add</button>
        <br>
    </form>
</div>
</div>
